# Copy thành .env.local và chỉnh theo môi trường của bạn.

# URL mà trình duyệt gọi API
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SIGNALR_URL=https://api-staging.relipacheck.io.vn

# dev-proxy.js (npm run dev)
API_PROXY_PORT=4000
API_PROXY_TARGET=https://api-staging.relipacheck.io.vn

# BE local trực tiếp — bỏ comment và dùng npm run dev:next
# NEXT_PUBLIC_API_URL=http://localhost:5104
# NEXT_PUBLIC_SIGNALR_URL=http://localhost:5104
