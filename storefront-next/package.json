{
  "name": "ezsim-storefront",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev -p 4444\" \"node dev-proxy.js\"",
    "dev:next": "next dev -p 4444",
    "dev:proxy": "node dev-proxy.js",
    "clean:fetch-cache": "node -e \"require('fs').rmSync('.next/cache/fetch-cache', { recursive: true, force: true })\"",
    "build": "cross-env NEXT_PUBLIC_API_URL=https://api-staging.relipacheck.io.vn next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.5.2",
    "@fortawesome/free-brands-svg-icons": "^6.5.2",
    "@fortawesome/free-solid-svg-icons": "^6.5.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@microsoft/signalr": "^10.0.0",
    "@types/sanitize-html": "^2.16.1",
    "next": "14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.77.0",
    "sanitize-html": "^2.17.4",
    "sonner": "^2.0.7",
    "zod": "^4.4.3",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3"
  }
}
